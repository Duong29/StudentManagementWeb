@model StudentManagementWeb.Models.Student

<h2>Cập nhật sinh viên</h2>

<form asp-action="Edit" method="post">
    <div class="mb-3">
        <label>Tên</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Tuổi</label>
        <input asp-for="Age" class="form-control" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>GPA</label>
        <input asp-for="Gpa" class="form-control" />
        <span asp-validation-for="Gpa" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Lớp</label>
        <input asp-for="ClassName" class="form-control" />
        <span asp-validation-for="ClassName" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success" onclick="return confirm('Bạn có chắc chắn muốn cập nhật thông tin?')">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>

</form>